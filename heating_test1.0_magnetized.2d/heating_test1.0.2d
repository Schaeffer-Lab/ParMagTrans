!----------global simulation parameters----------
simulation 
{
  !algorithm = "cuda", 
}

!--------the node configuration for this simulation--------
node_conf 
{
  node_number(1:2) = 4, 4,
  if_periodic(1:2) = .true., .true.,
  !tile_number(1:2) = 128,16,
  n_threads = 2,
}

!----------spatial grid----------
grid
{
  nx_p(1:2) =  2048, 2048,
  coordinates = "cartesian",
}

!----------time step and global data dump timestep number----------
time_step 
{
  dt     =  3.4e-2,
  ndump  =  16, 
}

!----------restart information----------
restart
{
}

!----------spatial limits of the simulations----------
space 
{
  xmin(1:2) =  -50.0, -50.0,
  xmax(1:2) =  50.0, 50.0,
}

!----------time limits ----------
time 
{
  tmin = 0.0d0, tmax  = 100,
}

!----------field solver set up----------

el_mag_fld 
{
  ext_fld = "static",
  type_ext_b(1:3) = "math func", "math func", "math func",
  ext_b_mfunc(1) = "0.0",
  ext_b_mfunc(2) = "0.03",
  ext_b_mfunc(3) = "0.0",
  
  type_ext_e(1:3) = "math func", "math func", "math func",
  ext_e_mfunc(1) = "0.0",
  ext_e_mfunc(2) = "0.0",
  ext_e_mfunc(3) = "0.0",
}


!----------boundary conditions for em-fields ----------
emf_bound 
{
}

!----------em-field diagnostics---------------
diag_emf
{
  ndump_fac = 1,
  ndump_fac_ene_int = 1,
  !reports = "part_e1", "part_e2", "part_e3", "part_b1", "part_b2", "part_b3",
}

!----------number of particle species----------
particles
{ 
  num_species = 2,
  interpolation = "cubic",
}

!----------information for ELECTRONS ----------
species
{
  name = "e",
  !num_par_max = 6000000,
  rqm=-1.0,
  num_par_x(1:2) = 4, 4, 
  !if_collide = .true.,
  !if_like_collide = .true.,
}



!----------information for ELECTRONS ----------

udist
{
  use_spatial_uth = .true.,
  spatial_uth(1:3) = "0.05*exp(-(x2^2)/(2*5^2))","0.05*exp(-(x2^2)/(2*5^2))","0.05*exp(-(x2^2)/(2*5^2))",
  !uth(1:3) = 0.01,0.01,0.01,
}
!----------boundary conditions for ELECTRONS----------

spe_bound
{
}

diag_species
{
 ndump_fac = 1, 
 reports = "charge",
 rep_udist = "ufl1","uth1","uth2",
 ndump_fac_ene = 1,
 ndump_fac_pha = 1, 

 ps_xmin(1:2) =  -100, -100,
 ps_xmax(1:2) =  100.0, 100.0,
 ps_nx(1:2)   =  1024, 1024,
 ps_pmin(1:3) = -.4, -.4, -.4,
 ps_pmax(1:3) = .4,  .4,  .4,
 ps_np(1:3)   = 1024,  1024,  1024,
 if_ps_p_auto(1:3) = .false., .false., .false., 

 ps_gammamin = 1.0, 
 ps_gammamax = 1.001,
 ps_ngamma = 1024,
 if_ps_gamma_auto = .true.,

 !phasespaces = "p1x1", "p2x1", "p2x1", "p2x2",
}

!----------information for IONS ----------
species
{
  name = "i",
  !num_par_max = 6000000,
  rqm=100.0,
  num_par_x(1:2) = 4, 4,
  !q_real = 1.0,
  !if_collide = .true.,
  !if_like_collide = .true.,
}



!----------information for species IONS ----------

udist
{
  use_spatial_uth = .true.,
  spatial_uth(1:3) = "0.005*exp(-(x2^2)/(2*5^2))","0.005*exp(-(x2^2)/(2*5^2))","0.005*exp(-(x2^2)/(2*5^2))",
  !uth(1:3) = 0.001,0.001,0.001,
}


!----------boundary conditions for IONS ----------

spe_bound
{
}



!----------diagnostic for IONS ----------

diag_species
{
 ndump_fac = 1, 
 reports = "charge",
 rep_udist = "ufl1","uth1","uth2",
 ndump_fac_ene = 1,
 ndump_fac_pha = 1, 
 ndump_fac_raw = 0,

 ps_xmin(1:2) =  -100, -100,
 ps_xmax(1:2) =  100.0, 100.0,
 ps_nx(1:2)   =  1024, 1024,
 ps_pmin(1:3) = -.4, -.4, -.4,
 ps_pmax(1:3) = .4,  .4,  .4,
 ps_np(1:3)   = 1024,  1024,  256,
 if_ps_p_auto(1:3) = .false., .false., .false., 

 ps_gammamin = 1.0, 
 ps_gammamax = 1.001,
 ps_ngamma = 1024,
 if_ps_gamma_auto = .true.,

 !phasespaces = "p1x1", "p2x1", "p2x1", "p2x2",
}


!----------smoothing for currents----------
smooth
{
!  type(1:2) = "compensated", "compensated",
}

!----------end of the input deck----------
